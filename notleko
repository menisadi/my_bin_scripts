#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["rich", "python-chess"]
# ///
import argparse
import shutil
import sys
from datetime import date
from pathlib import Path

import chess
import chess.engine
import chess.pgn
from rich.console import Console
from rich.text import Text

console = Console()

DEFAULT_ENGINE = shutil.which("stockfish")

PIECES = {
    (chess.PAWN, chess.WHITE): "♙",
    (chess.KNIGHT, chess.WHITE): "♘",
    (chess.BISHOP, chess.WHITE): "♗",
    (chess.ROOK, chess.WHITE): "♖",
    (chess.QUEEN, chess.WHITE): "♕",
    (chess.KING, chess.WHITE): "♔",
    (chess.PAWN, chess.BLACK): "♟",
    (chess.KNIGHT, chess.BLACK): "♞",
    (chess.BISHOP, chess.BLACK): "♝",
    (chess.ROOK, chess.BLACK): "♜",
    (chess.QUEEN, chess.BLACK): "♛",
    (chess.KING, chess.BLACK): "♚",
}

SQ_LIGHT = "on #f0d9b5"
SQ_DARK = "on #b58863"
SQ_LIGHT_HL = "on #cdd26a"
SQ_DARK_HL = "on #aaa23a"
PIECE_WHITE = "bold #ffffff"
PIECE_BLACK = "bold #1a1a1a"


def draw_board(board: chess.Board, flipped: bool, last_move: chess.Move | None) -> None:
    highlighted = {last_move.from_square, last_move.to_square} if last_move else set()
    ranks = range(7, -1, -1) if not flipped else range(8)
    files = range(8) if not flipped else range(7, -1, -1)

    console.print()
    for rank in ranks:
        row = Text()
        row.append(f" {rank + 1} ", style="bold white")
        for file in files:
            sq = chess.square(file, rank)
            light = (rank + file) % 2 == 1
            hl = sq in highlighted
            bg = (
                (SQ_LIGHT_HL if light else SQ_DARK_HL)
                if hl
                else (SQ_LIGHT if light else SQ_DARK)
            )
            piece = board.piece_at(sq)
            if piece:
                symbol = PIECES[(piece.piece_type, piece.color)]
                fg = PIECE_WHITE if piece.color == chess.WHITE else PIECE_BLACK
                row.append(f" {symbol} ", style=f"{fg} {bg}")
            else:
                row.append("   ", style=bg)
        console.print(row)

    file_names = "abcdefgh" if not flipped else "hgfedcba"
    labels = Text("    ")
    for f in file_names:
        labels.append(f" {f} ", style="bold white")
    console.print(labels)
    console.print()


def game_over_message(board: chess.Board) -> str | None:
    if board.is_checkmate():
        winner = "Black" if board.turn == chess.WHITE else "White"
        return f"Checkmate! {winner} wins."
    if board.is_stalemate():
        return "Stalemate — draw."
    if board.is_insufficient_material():
        return "Draw by insufficient material."
    if board.is_fifty_moves():
        return "Draw by fifty-move rule."
    if board.is_repetition(3):
        return "Draw by threefold repetition."
    return None


def load_game(path: Path) -> tuple[chess.pgn.Game, chess.Board, chess.Move | None]:
    with open(path, encoding="utf-8") as f:
        game = chess.pgn.read_game(f)
    if game is None:
        console.print(f"[red]No game found in {path}[/red]")
        sys.exit(1)
    end_node = game.end()
    board = end_node.board()
    last_move = end_node.move
    return game, board, last_move


def save_pgn(game: chess.pgn.Game, path: Path) -> None:
    with open(path, "w", encoding="utf-8") as f:
        print(game, file=f)


def _sanitize_comment(text: str) -> str:
    # PGN comments are wrapped in { }, so a literal } would break parsing
    return text.replace("}", ")")


def print_status(
    board: chess.Board, last_move: chess.Move | None, flipped: bool = False
) -> None:
    draw_board(board, flipped=flipped, last_move=last_move)
    msg = game_over_message(board)
    if msg:
        console.print(f"[bold green]{msg}[/bold green]")
        outcome = board.outcome()
        if outcome:
            console.print(f"Result: {outcome.result()}")
    else:
        turn = "White" if board.turn == chess.WHITE else "Black"
        console.print(f"Turn: [bold]{turn}[/bold]  Move: {board.fullmove_number}")
    console.print(f"FEN: [dim]{board.fen()}[/dim]")


def _flipped(game: chess.pgn.Game) -> bool:
    return game.headers.get("White") == "Stockfish"


def _player_color(game: chess.pgn.Game) -> chess.Color:
    return chess.BLACK if game.headers.get("White") == "Stockfish" else chess.WHITE


def cmd_new(args: argparse.Namespace) -> None:
    path = Path(args.file)
    if path.exists() and not args.force:
        console.print(f"[red]{path} already exists. Use --force to overwrite.[/red]")
        sys.exit(1)

    game = chess.pgn.Game()
    game.headers["White"] = args.name if args.color == "white" else "Stockfish"
    game.headers["Black"] = "Stockfish" if args.color == "white" else args.name
    game.headers["Date"] = date.today().strftime("%Y.%m.%d")
    game.headers["Result"] = "*"
    game.headers["IllegalAttempts"] = "0"
    save_pgn(game, path)

    board = chess.Board()
    console.print(
        f"[green]New game started. Playing as {args.name} ({'White' if args.color == 'white' else 'Black'}).[/green]"
    )
    print_status(board, last_move=None, flipped=(args.color == "black"))


def cmd_status(args: argparse.Namespace) -> None:
    game, board, last_move = load_game(Path(args.file))
    print_status(board, last_move, flipped=_flipped(game))
    count = int(game.headers.get("IllegalAttempts", "0"))
    if count:
        console.print(f"Illegal move attempts: [bold red]{count}[/bold red]")


def cmd_move(args: argparse.Namespace) -> None:
    path = Path(args.file)
    game, board, _ = load_game(path)

    over = game_over_message(board)
    if over:
        console.print(f"[red]Game is already over: {over}[/red]")
        sys.exit(1)

    if board.turn != _player_color(game):
        console.print(
            "[red]Not your turn — Stockfish to move. Run `engine` to let it play.[/red]"
        )
        sys.exit(1)

    try:
        move = chess.Move.from_uci(args.uci)
    except ValueError:
        console.print(f"[red]Invalid UCI format: {args.uci!r}. Example: e2e4[/red]")
        sys.exit(1)

    if move not in board.legal_moves:
        count = int(game.headers.get("IllegalAttempts", "0")) + 1
        game.headers["IllegalAttempts"] = str(count)
        save_pgn(game, path)
        piece = board.piece_at(move.from_square)
        if (
            move.promotion is None
            and piece is not None
            and piece.piece_type == chess.PAWN
            and chess.square_rank(move.to_square) in (0, 7)
        ):
            options = "  ".join(args.uci + p for p in "qrbn")
            console.print(
                "[red]Pawn promotion requires a promotion piece. Try one of:[/red]"
            )
            console.print(f"  {options}")
        else:
            console.print(f"[red]Illegal move: {args.uci}[/red]")
        sys.exit(1)

    san = board.san(move)
    node = game.end().add_variation(move)
    if args.reason:
        node.comment = _sanitize_comment(args.reason)
    board.push(move)

    over = game_over_message(board)
    if over:
        outcome = board.outcome()
        if outcome:
            game.headers["Result"] = outcome.result()

    save_pgn(game, path)
    console.print(f"Played: [bold]{san}[/bold]  ({args.uci})")
    print_status(board, move, flipped=_flipped(game))


def cmd_engine(args: argparse.Namespace) -> None:
    path = Path(args.file)
    game, board, _ = load_game(path)

    over = game_over_message(board)
    if over:
        console.print(f"[red]Game is already over: {over}[/red]")
        sys.exit(1)

    if board.turn == _player_color(game):
        console.print("[red]Not Stockfish's turn — use `move` to play your move.[/red]")
        sys.exit(1)

    if args.engine is None:
        console.print(
            "[red]Stockfish not found on PATH. Install it (e.g. `brew install stockfish`) "
            "or pass --engine /path/to/stockfish.[/red]"
        )
        sys.exit(1)

    try:
        engine = chess.engine.SimpleEngine.popen_uci(args.engine)
    except Exception as e:
        console.print(f"[red]Cannot start engine: {e}[/red]")
        sys.exit(1)

    if args.skill < 20:
        if "Skill Level" in engine.options:
            engine.configure({"Skill Level": args.skill})
        else:
            console.print(
                "[yellow]Warning: this engine does not support Skill Level — playing at full strength.[/yellow]"
            )

    try:
        result = engine.play(board, chess.engine.Limit(depth=args.depth))
        move = result.move
        san = board.san(move)
        game.end().add_variation(move)
        board.push(move)

        over = game_over_message(board)
        if over:
            outcome = board.outcome()
            if outcome:
                game.headers["Result"] = outcome.result()

        save_pgn(game, path)
        console.print(f"Engine played: [bold]{san}[/bold]  ({move.uci()})")
        print_status(board, move, flipped=_flipped(game))
    finally:
        engine.quit()


def cmd_comment(args: argparse.Namespace) -> None:
    path = Path(args.file)
    game, board, _ = load_game(path)

    last_node = game.end()
    if last_node == game:
        console.print("[red]No moves in the game yet.[/red]")
        sys.exit(1)

    new_comment = _sanitize_comment(args.comment)
    if last_node.comment and not args.replace:
        last_node.comment = f"{last_node.comment}. {new_comment}"
    else:
        last_node.comment = new_comment

    save_pgn(game, path)
    console.print("[green]Comment added to last move.[/green]")


def cmd_legal_moves(args: argparse.Namespace) -> None:
    path = Path(args.file)
    game, board, _ = load_game(path)

    over = game_over_message(board)
    if over:
        console.print(f"[red]Game is already over: {over}[/red]")
        sys.exit(1)

    moves = sorted(board.legal_moves, key=lambda m: board.san(m))
    console.print(f"[bold]Legal moves ({len(moves)}):[/bold]")
    for move in moves:
        san = board.san(move)
        console.print(f"  {move.uci():6} {san}")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Chess CLI — play or let an agent play against Stockfish, one move per invocation."
    )
    parser.add_argument(
        "--file", default="game.pgn", help="PGN state file (default: game.pgn)"
    )

    sub = parser.add_subparsers(dest="command", required=True)

    p_new = sub.add_parser("new", help="Start a new game")
    p_new.add_argument(
        "--color", choices=["white", "black"], default="white", help="Human/agent color"
    )
    p_new.add_argument("--name", default="Player", help="Player name for PGN headers")
    p_new.add_argument(
        "--force", action="store_true", help="Overwrite an existing game file"
    )

    sub.add_parser("status", help="Show current board, FEN, and whose turn it is")

    p_move = sub.add_parser("move", help="Play a move in UCI format (e.g. e2e4)")
    p_move.add_argument("uci", help="Move in UCI format")
    p_move.add_argument(
        "--reason", help="Reasoning for the move (saved as PGN comment)"
    )

    p_engine = sub.add_parser("engine", help="Let Stockfish play the next move")
    p_engine.add_argument(
        "--engine",
        default=DEFAULT_ENGINE,
        help="Path to Stockfish binary",
    )
    p_engine.add_argument(
        "--depth", type=int, default=15, help="Stockfish search depth (default: 15)"
    )
    p_engine.add_argument(
        "--skill",
        type=int,
        default=20,
        metavar="0-20",
        help="Engine skill level 0 (weakest) to 20 (strongest, default)",
    )

    p_comment = sub.add_parser(
        "comment", help="Add or append a comment to the last move"
    )
    p_comment.add_argument("comment", help="Comment text")
    p_comment.add_argument(
        "--replace",
        action="store_true",
        help="Replace existing comment instead of appending",
    )

    sub.add_parser("legal-moves", help="List all legal moves in the current position")

    args = parser.parse_args()
    {
        "new": cmd_new,
        "status": cmd_status,
        "move": cmd_move,
        "engine": cmd_engine,
        "comment": cmd_comment,
        "legal-moves": cmd_legal_moves,
    }[args.command](args)


if __name__ == "__main__":
    main()
